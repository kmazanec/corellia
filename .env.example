# Corellia environment — copy to `.env` (gitignored). Real environment
# variables always win over values in this file.
#
#   cp .env.example .env

# ── The live brain (OpenRouter) ──────────────────────────────────────────
# Create a key at https://openrouter.ai/keys, then run: npm run live
OPENROUTER_API_KEY=

# Optional per-tier model overrides (defaults live in src/brains/openrouter.ts;
# browse https://openrouter.ai/models for current IDs)
# CORELLIA_MODEL_LOW=deepseek/deepseek-v4-flash
# CORELLIA_MODEL_MID=deepseek/deepseek-v4-pro
# CORELLIA_MODEL_HIGH=qwen/qwen3-235b-a22b

# ── The Postgres substrate ───────────────────────────────────────────────
# Start the dev database with: docker compose up -d
# Setting DATABASE_URL also enables the pg integration tests in the suite.
# DATABASE_URL=postgres://postgres:corellia@localhost:54329/postgres

# Password for the docker-compose dev postgres (compose reads .env natively)
# POSTGRES_PASSWORD=corellia

# ══════════════════════════════════════════════════════════════════════════
# CONTAINER DEPLOYMENT (F-66) — `docker compose up --build`
#
# compose.yaml reads THIS file via `env_file:` and injects it into the daemon
# and postgres services. PLACEHOLDER VALUES ONLY below — copy to `.env`
# (gitignored) and replace each placeholder. NO secret is ever baked into the
# image or written into compose.yaml (ADR-012). Uncomment + set these when
# running the containerized daemon (distinct from the local `npm run live`
# flow above, which talks to a host-side dev DB on port 54329).
# ══════════════════════════════════════════════════════════════════════════

# ── Front door (REQUIRED) ─────────────────────────────────────────────────
# Bearer token every webhook request must carry. The daemon exits 1 if unset.
# Generate a strong random value, e.g.:  openssl rand -hex 32
# FRONT_DOOR_TOKEN=replace-me-with-a-long-random-token

# Port the daemon listens on INSIDE the container (default 8080). The compose
# healthcheck and the published port both assume 8080 unless you change both.
# FRONT_DOOR_PORT=8080

# Host-side published port (maps to container 8080). Override to avoid clashes.
# HOST_PORT=8080

# ── Substrate / Postgres for the container (REQUIRED) ─────────────────────
# In the container the daemon reaches Postgres at host `postgres` (the compose
# service name), NOT localhost:54329. On cold boot it runs CREATE TABLE IF NOT
# EXISTS (schema migration). The password here MUST match POSTGRES_PASSWORD.
# DATABASE_URL=postgres://postgres:replace-me-with-db-password@postgres:5432/postgres
# POSTGRES_USER=postgres
# POSTGRES_PASSWORD=replace-me-with-db-password

# ── Git / target repo (REQUIRED for real runs) ────────────────────────────
# Token for git operations against the target repo (push, PR, etc.).
# GITHUB_TOKEN=replace-me-with-a-github-token

# Absolute host path to the target repo the factory operates on. Mounted into
# the container at /workspace. v1 CONSTRAINT: the target repo must be a
# Node/TypeScript project — the image ships Node only; scripts declared in the
# target repo's package.json run INSIDE this container.
# TARGET_REPO_PATH=/absolute/path/to/your/target-repo

# ── Standing envelope (OPTIONAL — improvement loop, ADR-027) ──────────────
# Both must be present for the envelope to activate; omit both to disable.
# STANDING_BUDGET_JSON={"usd":5,"tokens":2000000,"toolCalls":500,"wallClockMs":1800000}
# STANDING_SPEND_CEILING_USD=5
