# Corellia environment — copy to `.env` (gitignored). Real environment
# variables always win over values in this file.
#
#   cp .env.example .env

# ── The live brain (OpenRouter) ──────────────────────────────────────────
# Create a key at https://openrouter.ai/keys, then run: npm run live
OPENROUTER_API_KEY=

# ── Model catalog (ADR-044) ──────────────────────────────────────────────
# The concrete model per call comes from a capability/cost-tagged catalog, not
# from a fixed model per tier. A tier (low/mid/high) is a capability-DEMAND band;
# the catalog picks the CHEAPEST model in that band that satisfies the call's
# needs (vision, context window, tool-calling), falling to a higher band when the
# demanded one cannot. The default catalog lives in src/brains/model-catalog.ts.

# Legacy per-band PINS (backward compatible): each forces its band's preferred
# model id. Unset → the band resolves to its cheapest satisfying catalog default
# under a minToolCalling 'ok' floor (currently deepseek flash / deepseek v4-pro /
# glm-5.2 — 'weak'-tagged models such as the qwen entries are never auto-picked;
# pin one explicitly to opt in). Browse current IDs at
# https://openrouter.ai/models
# CORELLIA_MODEL_LOW=deepseek/deepseek-v4-flash
# CORELLIA_MODEL_MID=deepseek/deepseek-v4-pro
# CORELLIA_MODEL_HIGH=z-ai/glm-5.2

# Extend or replace the catalog. Either INLINE JSON (starts with `[`) or a PATH to
# a JSON file. Entries merge into the default catalog BY id: a partial entry
# patches that model's fields; a new id is appended (omitted fields get
# conservative defaults). Fields: id (required), capability 1-10, costInPerMtok,
# costOutPerMtok, context, vision, toolCalling (weak|ok|strong), and optional
# endpoint / provider / requestTimeoutMs. Costs/capability are RANKING METADATA,
# not billing truth (real spend comes from provider usage accounting).
#
#   Re-tag an existing model (e.g. mark GLM cheaper) — inline:
# CORELLIA_MODELS_JSON=[{"id":"z-ai/glm-5.2","costInPerMtok":0.5,"costOutPerMtok":2.0}]
#
#   Add a LOCAL model via its own endpoint (Ollama — no api key needed). The
#   endpoint.baseUrl override is what routes this model off OpenRouter to your
#   local server; apiKeyEnv is unset because a local Ollama needs no key:
# CORELLIA_MODELS_JSON=[{"id":"llama3.1","capability":5,"context":128000,"endpoint":{"baseUrl":"http://localhost:11434/v1"}}]
#
#   Or point at a file of specs instead of inlining:
# CORELLIA_MODELS_JSON=/etc/corellia/models.json

# ── The Postgres substrate ───────────────────────────────────────────────
# Start the dev database with: docker compose up -d
# Setting DATABASE_URL also enables the pg integration tests in the suite.
# DATABASE_URL=postgres://postgres:corellia@localhost:54329/postgres

# Password for the docker-compose dev postgres (compose reads .env natively)
# POSTGRES_PASSWORD=corellia

# ── The JSONL event log (used when DATABASE_URL is unset) ─────────────────
# Explicit override for the event-log file. When unset, the default is
# per-target-repo: out/<sanitized-basename-of-CORELLIA_REPO_ROOT>/events.jsonl,
# so runs against different target repos never clobber each other's log. If no
# target repo is discernible, the flat legacy default out/events.jsonl is used.
# Set this only to pin a specific path (it always wins over the per-repo default).
# CORELLIA_EVENTS_PATH=out/events.jsonl

# ══════════════════════════════════════════════════════════════════════════
# CONTAINER DEPLOYMENT (F-66) — `docker compose up --build`
#
# compose.yaml reads THIS file via `env_file:` and injects it into the daemon
# and postgres services. PLACEHOLDER VALUES ONLY below — copy to `.env`
# (gitignored) and replace each placeholder. NO secret is ever baked into the
# image or written into compose.yaml (ADR-012). Uncomment + set these when
# running the containerized daemon (distinct from the local `npm run live`
# flow above, which talks to a host-side dev DB on port 54329).
# ══════════════════════════════════════════════════════════════════════════

# ── Front door (REQUIRED) ─────────────────────────────────────────────────
# Bearer token every webhook request must carry. The daemon exits 1 if unset.
# Generate a strong random value, e.g.:  openssl rand -hex 32
# FRONT_DOOR_TOKEN=replace-me-with-a-long-random-token

# Port the daemon listens on INSIDE the container (default 8080). The compose
# healthcheck and the published port both assume 8080 unless you change both.
# FRONT_DOOR_PORT=8080

# Host-side published port (maps to container 8080). Override to avoid clashes.
# HOST_PORT=8080

# ── Substrate / Postgres for the container (REQUIRED) ─────────────────────
# In the container the daemon reaches Postgres at host `postgres` (the compose
# service name), NOT localhost:54329. On cold boot it runs CREATE TABLE IF NOT
# EXISTS (schema migration). The password here MUST match POSTGRES_PASSWORD.
# DATABASE_URL=postgres://postgres:replace-me-with-db-password@postgres:5432/postgres
# POSTGRES_USER=postgres
# POSTGRES_PASSWORD=replace-me-with-db-password

# ── Git / target repo (REQUIRED for real runs) ────────────────────────────
# Token for git operations against the target repo (push, PR, etc.).
# GITHUB_TOKEN=replace-me-with-a-github-token

# Absolute host path to the target repo the factory operates on. Mounted into
# the container at /workspace. v1 CONSTRAINT: the target repo must be a
# Node/TypeScript project — the image ships Node only; scripts declared in the
# target repo's package.json run INSIDE this container.
# TARGET_REPO_PATH=/absolute/path/to/your/target-repo

# ── Worktree reaper (OPTIONAL — issue D4) ─────────────────────────────────
# Each run reaps stale tree worktrees under <repo>/.corellia/worktrees/ before
# opening its own. By default it removes ONLY worktrees whose branch is fully
# merged into the current branch (their work is already in history) and never
# touches uncommitted salvage. Set to 1 to also clear clean-but-unmerged tree
# worktrees (their branch tip survives the checkout removal).
# CORELLIA_REAP_WORKTREES=1

# ── Standing envelope (OPTIONAL — improvement loop, ADR-027) ──────────────
# Both must be present for the envelope to activate; omit both to disable.
# STANDING_BUDGET_JSON={"usd":5,"tokens":2000000,"toolCalls":500,"wallClockMs":1800000}
# STANDING_SPEND_CEILING_USD=5
